{
  "name": "glicko-films",
  "version": "3.0.0",
  "description": "Tomasino's Glicko-2 film rankings app.",
  "author": "A morsecodemedia/tomasino project",
  "contributors": [
    {
      "name": "Brandon Morse",
      "email": "brandon@morsecodemedia.com",
      "url": "https://github.com/morsecodemedia"
    },
    {
      "name": "James Tomasino",
      "email": "james@tomasino.org",
      "url": "https://github.com/jamestomasino"
    }
  ],
  "private": true,
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx netlify dev:exec drizzle-kit migrate",
    "db:studio": "npx netlify dev:exec drizzle-kit studio",
    "seed:elo": "npx netlify dev:exec -- node scripts/seed-tmdb-elo.mjs",
    "cache:images": "npx netlify dev:exec -- node scripts/cache-film-images.mjs",
    "smoke:api": "node scripts/smoke-api.mjs"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.4",
    "@netlify/neon": "^0.1.2",
    "drizzle-orm": "^0.45.2",
    "glicko2": "^0.8.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "drizzle-kit": "^0.31.10",
    "vite": "^5.4.19"
  }
}
